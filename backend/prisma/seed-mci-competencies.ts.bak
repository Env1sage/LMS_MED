async function seedMCICompetencies() {
  console.log('🏥 Starting MCI Competency Seeding...\n');

  // Get Bitflow Owner user
  const bitflowOwner = await prisma.users.findFirst({
    where: { role: 'BITFLOW_OWNER' },
  });

  if (!bitflowOwner) {
    throw new Error('Bitflow Owner not found. Please run seed-phase0 first.');
  }

  let created = 0;
  let skipped = 0;

  for (const comp of mciCompetencies) {
    // Check if competency already exists
    const existing = await prisma.competencies.findFirst({
      where: {
        code: comp.code,
        subject: comp.subject,
      },
    });

    if (existing) {
      skipped++;
      continue;
    }

    // Create competency
    await prisma.competencies.create({
      data: {
        id: `comp_mci_${comp.code.toLowerCase().replace(/[^a-z0-9]/g, '_')}_${Date.now()}_${Math.random().toString(36).substring(7)}`,
        code: comp.code,
        title: comp.description.substring(0, 100), // Truncate for title
        description: `${comp.topic}: ${comp.description}`,
        subject: comp.subject,
        domain: comp.domain === 'Knowledge' ? 'COGNITIVE' : comp.domain === 'Skills' ? 'PSYCHOMOTOR' : 'AFFECTIVE',
        academicLevel: comp.level === 'Beginner' ? 'UNDERGRADUATE_YEAR_1' : 
                       comp.level === 'Intermediate' ? 'UNDERGRADUATE_YEAR_3' : 'POSTGRADUATE',
        status: CompetencyStatus.ACTIVE,
        version: 1,
        createdBy: bitflowOwner.id,
        updatedAt: new Date(),
      },
    });

    created++;
  }

  console.log(`\n✅ MCI Competency Seeding Complete!`);
  console.log(`   Created: ${created} competencies`);
  console.log(`   Skipped: ${skipped} (already exist)`);
  console.log(`   Total MCI Competencies: ${mciCompetencies.length}\n`);
}

async function main() {
  try {
    await seedMCICompetencies();
  } catch (error) {
    console.error('Error seeding MCI competencies:', error);
    throw error;
  } finally {
    await prisma.$disconnect();
  }
}

main();
