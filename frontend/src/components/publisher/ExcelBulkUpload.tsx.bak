import React, { useState, useRef, useCallback, useEffect } from 'react';
import learningUnitService from '../../services/learning-unit.service';
import topicsService from '../../services/topics.service';
import {
  Upload, Download, FileSpreadsheet, Check, X, ChevronDown, ChevronRight,
  BookOpen, Trash2, Send, AlertCircle, FileText, Video, BookMarked, Image
} from 'lucide-react';

interface ExcelRow {
  id: string;
  isbn: string;
  title: string;
  author: string;
  description: string;
  coverImageUrl: string;
  fileUrl: string;
  subject: string;
  topic: string;
  subTopic: string;
  difficultyLevel: string;
  estimatedDuration: number;
  type: 'BOOK' | 'VIDEO' | 'EPUB';
  deliveryType: 'REDIRECT' | 'EMBED' | 'STREAM';
  watermarkEnabled: boolean;
  downloadAllowed: boolean;
  viewOnly: boolean;
  sessionExpiryMinutes: number;
  valid: boolean;
  errors: string[];
}

interface ExcelBulkUploadProps {
  onSuccess?: () => void;
}

// ── Excel (XML SpreadsheetML) template generators ──────────────────────────

const xmlEscape = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

function makeDropdownXml(opts: string[]) {
  return `<Data ss:Type="String">${xmlEscape(opts[0])}</Data>`;
}

function buildExcelXml(columns: Array<{ header: string; width?: number; dropdown?: string[]; example1: string; example2: string }>, sheetName: string): string {
  const headerStyle = `<Style ss:ID="h"><Alignment ss:Horizontal="Center" ss:Vertical="Center" ss:WrapText="1"/><Font ss:Bold="1" ss:Color="#FFFFFF" ss:Size="11" ss:Name="Calibri"/><Interior ss:Color="#1D4ED8" ss:Pattern="Solid"/><Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#FFFFFF"/></Borders></Style>`;
  const cellStyle = `<Style ss:ID="c"><Alignment ss:Vertical="Center" ss:WrapText="1"/><Font ss:Size="11" ss:Name="Calibri"/></Style>`;
  const reqStyle  = `<Style ss:ID="r"><Alignment ss:Vertical="Center" ss:WrapText="1"/><Font ss:Bold="1" ss:Size="11" ss:Name="Calibri"/><Interior ss:Color="#FFF9C4" ss:Pattern="Solid"/></Style>`;
  const exStyle   = `<Style ss:ID="ex"><Alignment ss:Vertical="Center" ss:WrapText="1"/><Font ss:Italic="1" ss:Color="#6B7280" ss:Size="11" ss:Name="Calibri"/><Interior ss:Color="#F3F4F6" ss:Pattern="Solid"/></Style>`;

  const colDefs = columns.map(c => `<Column ss:Width="${c.width || 120}"/>`).join('');

  const headerRow = `<Row ss:Height="32">${columns.map(c => `<Cell ss:StyleID="h"><Data ss:Type="String">${xmlEscape(c.header)}</Data></Cell>`).join('')}</Row>`;

  const makeRow = (vals: string[]) =>
    `<Row ss:Height="22">${vals.map((v, i) => {
      const col = columns[i];
      if (col.dropdown && col.dropdown.length > 0) {
        return `<Cell ss:StyleID="c"><Data ss:Type="String">${xmlEscape(v || col.dropdown[0])}</Data></Cell>`;
      }
      return `<Cell ss:StyleID="c"><Data ss:Type="String">${xmlEscape(v)}</Data></Cell>`;
    }).join('')}</Row>`;

  // Example rows — first cell (ISBN/Code) uses EXAMPLE-001/EXAMPLE-002 as obviously fake identifiers
  // The parser filters rows where first cell starts with "EXAMPLE-"
  // Style-ID based detection won't work because Excel/LibreOffice preserves cell style when user edits cells
  const makeExampleRow = (vals: string[]) =>
    `<Row ss:Height="22">${vals.map(v =>
      `<Cell ss:StyleID="ex"><Data ss:Type="String">${xmlEscape(v)}</Data></Cell>`
    ).join('')}</Row>`;

  const ex1Row = makeExampleRow(columns.map(c => c.example1));
  const ex2Row = makeExampleRow(columns.map(c => c.example2));

  // Note row
  const noteRow = `<Row ss:Height="20"><Cell ss:MergeAcross="${columns.length - 1}" ss:StyleID="c"><Data ss:Type="String">💡 Tip: Replace the EXAMPLE rows above with your own data (change the EXAMPLE-001/EXAMPLE-002 code in column 1). Difficulty: K, KH, S, SH, P.</Data></Cell></Row>`;

  return `<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:x="urn:schemas-microsoft-com:office:excel">
 <Styles>${headerStyle}${cellStyle}${reqStyle}${exStyle}</Styles>
 <Worksheet ss:Name="${xmlEscape(sheetName)}">
  <Table>${colDefs}${headerRow}${ex1Row}${ex2Row}${noteRow}</Table>
  <WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel">
   <FreezePanes/><FrozenNoSplit/><SplitHorizontal>1</SplitHorizontal><TopRowBottomPane>1</TopRowBottomPane>
  </WorksheetOptions>
 </Worksheet>
</Workbook>`;
}

const SUBJECTS = [
  'Anatomy','Physiology','Biochemistry','Pharmacology','Pathology',
  'Microbiology','Forensic Medicine','Community Medicine','Medicine',
  'Surgery','Obstetrics & Gynaecology','Paediatrics','Orthopaedics',
  'Ophthalmology','ENT','Dermatology','Psychiatry','Radiology','Anaesthesia',
];
const DIFF_OPTS = ['K','KH','S','SH','P'];
const DELIVERY_OPTS = ['REDIRECT','EMBED','STREAM'];
const BOOL_OPTS = ['false','true'];

function downloadEbookTemplate() {
  const cols = [
    { header: 'ISBN *', width: 130, example1: 'EXAMPLE-BOOK-001', example2: 'EXAMPLE-BOOK-002' },
    { header: 'Title *', width: 200, example1: "Harrison's Principles of Internal Medicine", example2: 'Robbins Pathology' },
    { header: 'Author', width: 140, example1: 'Dennis Kasper et al', example2: 'Vinay Kumar' },
    { header: 'Description *', width: 240, example1: 'Comprehensive medical textbook covering all body systems', example2: 'Complete pathology reference for medical students' },
    { header: 'Cover Image URL', width: 160, example1: '/uploads/images/harrisons-cover.jpg', example2: '/uploads/images/robbins-cover.jpg' },
    { header: 'File URL (PDF) *', width: 180, example1: '/uploads/books/harrisons.pdf', example2: '/uploads/books/robbins.pdf' },
    { header: 'Subject *', width: 130, dropdown: SUBJECTS, example1: 'Medicine', example2: 'Pathology' },
    { header: 'Topic', width: 130, example1: 'General Medicine', example2: 'General Pathology' },
    { header: 'Sub-Topic', width: 130, example1: '', example2: 'Cell Injury' },
    { header: 'Difficulty *', width: 80, dropdown: DIFF_OPTS, example1: 'K', example2: 'KH' },
    { header: 'Duration (min)', width: 80, example1: '60', example2: '45' },
    { header: 'Delivery Type', width: 100, dropdown: DELIVERY_OPTS, example1: 'REDIRECT', example2: 'REDIRECT' },
    { header: 'Watermark', width: 80, dropdown: BOOL_OPTS, example1: 'true', example2: 'true' },
    { header: 'Download Allowed', width: 100, dropdown: BOOL_OPTS, example1: 'false', example2: 'false' },
    { header: 'View Only', width: 80, dropdown: BOOL_OPTS, example1: 'false', example2: 'true' },
    { header: 'Session Expiry (min)', width: 110, example1: '120', example2: '120' },
  ];
  const xml = buildExcelXml(cols, 'EBook Upload');
  const blob = new Blob([xml], { type: 'application/vnd.ms-excel' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'ebook_upload_template.xls';
  document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(a.href);
}

